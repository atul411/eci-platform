                "properties": {
                    "product_id": {
                        "type": "integer",
                        "title": "Product Id"
                    },
                    "sku": {
                        "type": "string",
                        "title": "Sku"
                    },
                    "name": {
                        "type": "string",
                        "title": "Name"
                    },
                    "category": {
                        "type": "string",
                        "title": "Category"
                    },
                    "price": {
                        "type": "number",
                        "title": "Price"
                    },
                    "is_active": {
                        "type": "boolean",
                        "title": "Is Active"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Created At"
                    }
                },
                "type": "object",
                "required": [
                    "product_id",
                    "sku",
                    "name",
                    "category",
                    "price",
                    "is_active",
                    "created_at"
                ],
                "title": "ProductOut"
            },
