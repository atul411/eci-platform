                    "name": {
                        "type": "string",
                        "title": "Name"
                    },
                    "category": {
                        "type": "string",
                        "title": "Category"
                    },
                    "price": {
                        "type": "number",
                        "title": "Price"
                    },
                    "is_active": {
                        "type": "boolean",
                        "title": "Is Active",
                        "default": true
                    }
